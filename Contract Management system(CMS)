// ─── NAVIGATION ──────────────────────────────────────────────────────────────
function navigate(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  const navEl = document.getElementById('nav-' + page);
  if (navEl) navEl.classList.add('active');
  const titles = { dashboard:'Dashboard', contracts:'All Contracts', review:'Pending Review', esign:'Awaiting E-Sign', plans:'Customer Plans', profitability:'Profitability Overview' };
  document.getElementById('page-title').textContent = titles[page] || '';
  renderPage(page);
}

function renderPage(page) {
  if (page === 'dashboard') renderDashboard();
  if (page === 'contracts') renderContracts();
  if (page === 'review') renderReview();
  if (page === 'esign') renderEsign();
  if (page === 'plans') renderPlans();
  if (page === 'profitability') renderProfitability();
}

// ─── ROLE ─────────────────────────────────────────────────────────────────────
function switchRole(role) {
  currentRole = role;
  const labels = { kam:'Key Account Manager', rsm:'Regional Sales Manager', sc:'Sales Controller' };
  document.getElementById('role-label').textContent = 'Logged in as: ' + labels[role];
  const showNew = role === 'kam';
  document.getElementById('btn-new-contract').style.display = showNew ? '' : 'none';
  renderPage(getCurrentPage());
  toast('Switched to ' + labels[role], 'success');
}

function getCurrentPage() {
  const active = document.querySelector('.page.active');
  return active ? active.id.replace('page-','') : 'dashboard';
}

// ─── DASHBOARD ────────────────────────────────────────────────────────────────
function renderDashboard() {
  const total = contracts.length;
  const review = contracts.filter(c => c.status === 'Under Review').length;
  const active = contracts.filter(c => c.status === 'Active').length;
  document.getElementById('stat-total').textContent = total;
  document.getElementById('stat-review').textContent = review;
  document.getElementById('stat-active').textContent = active;

  const tl = document.getElementById('dashboard-timeline');
  tl.innerHTML = activity.map((a, i) => `
    <div class="tl-item">
      <div class="tl-dot-col">
        <div class="tl-dot ${a.col}"></div>
        ${i < activity.length-1 ? '<div class="tl-line"></div>' : ''}
      </div>
      <div class="tl-content">
        <div class="tl-title">${a.text}</div>
        <div class="tl-sub">${a.sub}</div>
      </div>
    </div>
  `).join('');

  const statuses = ['Draft','Under Review','E-Sign','Active','Denied'];
  const counts = statuses.map(s => ({ s, n: contracts.filter(c=>c.status===s).length }));
  const colors = { 'Draft':'var(--muted)', 'Under Review':'var(--warn)', 'E-Sign':'var(--accent)', 'Active':'var(--success)', 'Denied':'var(--danger)' };
  document.getElementById('status-breakdown').innerHTML = counts.map(({s,n}) => `
    <div style="margin-bottom:14px">
      <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:4px">
        <span>${s}</span><span style="color:${colors[s]};font-weight:600">${n}</span>
      </div>
      <div class="profitability-bar"><div class="profitability-fill" style="width:${(n/contracts.length)*100}%;background:${colors[s]}"></div></div>
    </div>
  `).join('');

  document.getElementById('badge-contracts').textContent = contracts.length;
  document.getElementById('badge-review').textContent = contracts.filter(c=>c.status==='Under Review').length;
  document.getElementById('badge-plans').textContent = plans.filter(p=>p.status==='Pending Review').length;
}

// ─── CONTRACTS ────────────────────────────────────────────────────────────────
function filterContracts(v) { filterText = v.toLowerCase(); renderContracts(); }
function filterByStatus(v) { filterStatus = v; renderContracts(); }
function filterByRegion(v) { filterRegion = v; renderContracts(); }

function renderContracts() {
  let data = contracts;
  if (filterText) data = data.filter(c => c.customer.toLowerCase().includes(filterText) || c.id.toLowerCase().includes(filterText));
  if (filterStatus) data = data.filter(c => c.status === filterStatus);
  if (filterRegion) data = data.filter(c => c.region === filterRegion);

  // KAM only sees their own
  if (currentRole === 'kam') data = data.filter(c => c.kam === 'Alice Müller');

  const tbody = document.getElementById('contracts-table-body');
  if (!data.length) { tbody.innerHTML = `<tr><td colspan="8"><div class="empty">No contracts found.</div></td></tr>`; return; }
  tbody.innerHTML = data.map(c => `
    <tr>
      <td><span class="chip">${c.id}</span></td>
      <td><strong>${c.customer}</strong></td>
      <td style="color:var(--muted)">${c.kam}</td>
      <td>${c.region}</td>
      <td>€${c.value.toLocaleString()}</td>
      <td>${statusBadge(c.status)}</td>
      <td style="color:var(--muted)">${c.created}</td>
      <td><button class="btn btn-ghost btn-sm" onclick="openDetail('${c.id}')">View →</button></td>
    </tr>
  `).join('');
}

// ─── REVIEW ───────────────────────────────────────────────────────────────────
function renderReview() {
  const data = contracts.filter(c => c.status === 'Under Review');
  const alert = document.getElementById('review-role-alert');
  if (currentRole === 'kam') {
    alert.innerHTML = `<div class="alert-banner">⚠️ Review and approval is performed by Regional Sales Managers. Switch role to RSM to act on these.</div>`;
  } else if (currentRole === 'rsm') {
    alert.innerHTML = `<div style="background:rgba(34,201,122,0.08);border:1px solid rgba(34,201,122,0.2);border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:var(--success)">✅ As RSM you can approve, deny, or request changes on contracts below.</div>`;
  } else {
    alert.innerHTML = `<div class="alert-banner">ℹ️ Sales Controllers have read-only visibility on review queue.</div>`;
  }
  const tbody = document.getElementById('review-table-body');
  if (!data.length) { tbody.innerHTML = `<tr><td colspan="7"><div class="empty">No contracts pending review.</div></td></tr>`; return; }
  tbody.innerHTML = data.map(c => `
    <tr>
      <td><span class="chip">${c.id}</span></td>
      <td><strong>${c.customer}</strong></td>
      <td style="color:var(--muted)">${c.kam}</td>
      <td>€${c.value.toLocaleString()}</td>
      <td style="color:var(--muted)">${c.created}</td>
      <td><span style="color:${c.priority==='Urgent'?'var(--danger)':c.priority==='High'?'var(--warn)':'var(--muted)'}">${c.priority}</span></td>
      <td style="display:flex;gap:6px;flex-wrap:wrap">
        <button class="btn btn-ghost btn-sm" onclick="openDetail('${c.id}')">View</button>
        ${currentRole==='rsm' ? `
          <button class="btn btn-success btn-sm" onclick="reviewAction('${c.id}','approve')">✓ Approve</button>
          <button class="btn btn-danger btn-sm" onclick="reviewAction('${c.id}','deny')">✗ Deny</button>
          <button class="btn btn-warn btn-sm" onclick="reviewAction('${c.id}','changes')">↺ Changes</button>
        ` : ''}
      </td>
    </tr>
  `).join('');
}

function reviewAction(id, action) {
  const c = contracts.find(x => x.id === id);
  if (!c) return;
  if (action === 'approve') {
    c.status = 'E-Sign';
    c.comments.push({ author: 'RSM', text: 'Contract approved. Sent to customer for e-signature.' });
    toast(`${id} approved — sent for e-signature`, 'success');
    addActivity(`${id} approved by RSM`, 'Today · RSM', 'green');
  } else if (action === 'deny') {
    c.status = 'Denied';
    c.comments.push({ author: 'RSM', text: 'Contract denied. Please revise and resubmit.' });
    toast(`${id} denied`, '');
    addActivity(`${id} denied by RSM`, 'Today · RSM', '');
  } else {
    c.comments.push({ author: 'RSM', text: 'Changes requested. Please revise terms.' });
    toast(`Change request sent to ${c.kam}`, 'warn');
    addActivity(`Changes requested on ${id}`, 'Today · RSM', 'warn');
  }
  renderReview();
  updateBadges();
}

// ─── E-SIGN ───────────────────────────────────────────────────────────────────
function renderEsign() {
  const data = contracts.filter(c => c.status === 'E-Sign');
  const tbody = document.getElementById('esign-table-body');
  if (!data.length) { tbody.innerHTML = `<tr><td colspan="6"><div class="empty">No contracts awaiting e-signature.</div></td></tr>`; return; }
  tbody.innerHTML = data.map(c => `
    <tr>
      <td><span class="chip">${c.id}</span></td>
      <td><strong>${c.customer}</strong><br/><span style="font-size:11px;color:var(--muted)">${c.email}</span></td>
      <td style="color:var(--muted)">${c.created}</td>
      <td><span style="color:var(--warn)">5 days</span></td>
      <td>€${c.value.toLocaleString()}</td>
      <td>
        ${currentRole==='kam' ? `<button class="btn btn-primary btn-sm" onclick="markSigned('${c.id}')">Mark as Signed</button>` : '<span style="color:var(--muted);font-size:12px">Awaiting…</span>'}
      </td>
    </tr>
  `).join('');
}

function markSigned(id) {
  const c = contracts.find(x => x.id === id);
  if (!c) return;
  c.status = 'Active';
  c.signedDate = new Date().toISOString().split('T')[0];
  // Auto-create plan (RPA simulation)
  const existing = plans.find(p => p.contractRef === id);
  if (!existing) {
    plans.push({ id:'PLN-2024-00'+(plans.length+1), customer:c.customer, contractRef:id, rebate:c.rebate, volume:c.volume, status:'Pending Review', crm:'Pending' });
    toast(`Customer plan auto-created via RPA — pending SC review`, 'warn');
    addActivity(`${id} signed — plan auto-generated by RPA`, 'Today · System', 'green');
  }
  toast(`${id} marked as signed — now Active!`, 'success');
  renderEsign();
  updateBadges();
}

// ─── PLANS ────────────────────────────────────────────────────────────────────
function renderPlans() {
  const alert = document.getElementById('plan-role-alert');
  if (currentRole === 'sc') {
    alert.innerHTML = `<div style="background:rgba(34,201,122,0.08);border:1px solid rgba(34,201,122,0.2);border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:var(--success)">✅ As Sales Controller you can review and approve customer plans.</div>`;
  } else {
    alert.innerHTML = `<div class="alert-banner">ℹ️ Customer plans are reviewed and approved by the Sales Controller.</div>`;
  }
  const tbody = document.getElementById('plans-table-body');
  tbody.innerHTML = plans.map(p => `
    <tr>
      <td><span class="chip">${p.id}</span></td>
      <td><strong>${p.customer}</strong></td>
      <td><span class="chip" style="background:rgba(124,92,252,0.12);color:var(--accent2)">${p.contractRef}</span></td>
      <td>${p.rebate}%</td>
      <td>€${p.volume.toLocaleString()}</td>
      <td>${statusBadge(p.status)}</td>
      <td><span style="color:${p.crm==='Synced'?'var(--success)':'var(--muted)'}">${p.crm==='Synced'?'✓ Synced':'⏳ Pending'}</span></td>
      <td>
        ${currentRole==='sc' && p.status==='Pending Review' ? `<button class="btn btn-success btn-sm" onclick="approvePlan('${p.id}')">Approve & Sync</button>` : '—'}
      </td>
    </tr>
  `).join('');
}

function approvePlan(id) {
  const p = plans.find(x => x.id === id);
  if (!p) return;
  p.status = 'Approved';
  p.crm = 'Synced';
  toast(`${id} approved & synced to CRM + dashboards`, 'success');
  addActivity(`${p.id} approved by SC — synced to CRM`, 'Today · Sales Controller', 'green');
  renderPlans();
  updateBadges();
}

// ─── PROFITABILITY ────────────────────────────────────────────────────────────
function renderProfitability() {
  const tbody = document.getElementById('profit-table-body');
  tbody.innerHTML = profitData.map(p => {
    const net = p.value - p.rebate;
    return `
      <tr>
        <td><strong>${p.customer}</strong></td>
        <td>€${p.value.toLocaleString()}</td>
        <td style="color:var(--warn)">-€${p.rebate.toLocaleString()}</td>
        <td>€${net.toLocaleString()}</td>
        <td style="color:var(--success)">${p.margin}%</td>
        <td style="min-width:120px"><div class="profitability-bar"><div class="profitability-fill" style="width:${p.margin}%"></div></div><span style="font-size:11px;color:var(--muted)">${p.margin}%</span></td>
      </tr>
    `;
  }).join('');
}

// ─── DETAIL MODAL ─────────────────────────────────────────────────────────────
function openDetail(id) {
  const c = contracts.find(x => x.id === id);
  if (!c) return;
  selectedContractId = id;
  document.getElementById('detail-title').textContent = c.id;
  document.getElementById('detail-subtitle').textContent = c.customer + ' · ' + c.region;

  let stepsHtml = '';
  const allSteps = ['Draft','Under Review','Approved','E-Sign','Active'];
  const stepMap = { 'Draft':0,'Under Review':1,'Approved':2,'E-Sign':3,'Active':4,'Denied':1 };
  const cur = stepMap[c.status] ?? 0;
  stepsHtml = `<div class="steps" style="margin-bottom:20px">` +
    ['Draft','Review','Approved','E-Sign','Active'].map((s,i) => {
      const cls = i < cur ? 'done' : i === cur ? 'active' : '';
      const dot = i < cur ? '✓' : i+1;
      return `<div class="step ${cls}"><div class="step-dot">${dot}</div><div class="step-label">${s}</div></div>`;
    }).join('') + `</div>`;

  const commentsHtml = c.comments.length ? c.comments.map(cm => `
    <div class="comment"><div class="comment-author">${cm.author}</div><div class="comment-text">${cm.text}</div></div>
  `).join('') : '<p style="color:var(--muted);font-size:13px">No comments yet.</p>';

  document.getElementById('detail-body').innerHTML = `
    ${stepsHtml}
    <div class="detail-grid">
      <div class="detail-item"><label>Status</label><span>${statusBadge(c.status)}</span></div>
      <div class="detail-item"><label>Priority</label><span style="color:${c.priority==='Urgent'?'var(--danger)':c.priority==='High'?'var(--warn)':'var(--text)'}">${c.priority}</span></div>
      <div class="detail-item"><label>Value</label><span style="font-weight:600">€${c.value.toLocaleString()}</span></div>
      <div class="detail-item"><label>Template</label><span>${c.template}</span></div>
      <div class="detail-item"><label>Period</label><span>${c.start} → ${c.end}</span></div>
      <div class="detail-item"><label>Rebate</label><span>${c.rebate}%</span></div>
      <div class="detail-item"><label>Volume Target</label><span>€${c.volume.toLocaleString()}</span></div>
      <div class="detail-item"><label>Payment Terms</label><span>${c.payment}</span></div>
      <div class="detail-item"><label>Counterpart</label><span>${c.counterpart}</span></div>
      <div class="detail-item"><label>KAM</label><span>${c.kam}</span></div>
    </div>
    ${c.notes ? `<div style="background:var(--surface2);border-radius:8px;padding:14px;margin-bottom:16px;font-size:13px"><strong style="font-size:11px;color:var(--muted);text-transform:uppercase;display:block;margin-bottom:4px">Notes</strong>${c.notes}</div>` : ''}
    ${c.attachedFile ? `<div style="margin-bottom:16px"><strong style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;display:block;margin-bottom:6px">Attached Document</strong><div class="file-attachment">📎 ${c.attachedFile.name} <span style="color:var(--muted)">(${formatBytes(c.attachedFile.size)})</span></div></div>` : ''}
    <div style="margin-top:16px"><strong style="font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em">Comments & History</strong>
      <div class="comment-box">${commentsHtml}</div>
    </div>
  `;

  let footerBtns = `<button class="btn btn-ghost" onclick="closeModal('modal-contract-detail')">Close</button>`;
  if (currentRole === 'kam' && (c.status === 'Draft' || c.status === 'Denied')) {
    footerBtns += `<button class="btn btn-primary" onclick="submitForReview('${id}')">Submit for Review</button>`;
  }
  if (currentRole === 'rsm' && c.status === 'Under Review') {
    footerBtns += `
      <button class="btn btn-success" onclick="reviewAction('${id}','approve');closeModal('modal-contract-detail')">✓ Approve</button>
      <button class="btn btn-danger" onclick="reviewAction('${id}','deny');closeModal('modal-contract-detail')">✗ Deny</button>
      <button class="btn btn-warn" onclick="reviewAction('${id}','changes');closeModal('modal-contract-detail')">↺ Request Changes</button>
    `;
  }
  if (currentRole === 'kam' && c.status === 'E-Sign') {
    footerBtns += `<button class="btn btn-primary" onclick="markSigned('${id}');closeModal('modal-contract-detail')">Mark as Signed</button>`;
  }
  document.getElementById('detail-footer').innerHTML = footerBtns;
  openModal('modal-contract-detail');
}

function submitForReview(id) {
  const c = contracts.find(x => x.id === id);
  if (!c) return;
  c.status = 'Under Review';
  toast(`${id} submitted for RSM review`, 'success');
  addActivity(`${id} submitted for review`, 'Today · ' + c.kam, 'warn');
  closeModal('modal-contract-detail');
  renderPage(getCurrentPage());
  updateBadges();
}

// ─── NEW CONTRACT FORM ────────────────────────────────────────────────────────
function openNewContract() {
  if (currentRole !== 'kam') { toast('Only KAMs can create contracts', ''); return; }
  currentFormStep = 1;
  currentContractMode = 'form';
  uploadedFile = null;
  attachedFile = null;
  updateFormSteps();
  ['f-customer','f-email','f-value','f-notes','f-rebate','f-volume','f-obligations'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value='';
  });
  // Reset upload mode UI
  document.getElementById('contract-form-mode').style.display = '';
  document.getElementById('contract-upload-mode').style.display = 'none';
  document.querySelectorAll('.upload-tab').forEach((t,i) => t.classList.toggle('active', i===0));
  document.getElementById('contract-modal-footer').innerHTML = `
    <button class="btn btn-ghost" id="btn-form-back" style="display:none" onclick="formStep(-1)">← Back</button>
    <button class="btn btn-ghost" onclick="closeModal('modal-new-contract')">Cancel</button>
    <button class="btn btn-primary" id="btn-form-next" onclick="formStep(1)">Next →</button>
  `;
  openModal('modal-new-contract');
}

function formStep(dir) {
  if (dir === 1 && currentFormStep === 3) { submitNewContract(); return; }
  if (dir === 1 && currentFormStep === 2) {
    // populate review
    document.getElementById('review-customer').textContent = document.getElementById('f-customer').value || '—';
    document.getElementById('review-region').textContent = document.getElementById('f-region').value;
    document.getElementById('review-value').textContent = '€' + (parseInt(document.getElementById('f-value').value)||0).toLocaleString();
    document.getElementById('review-template').textContent = document.getElementById('f-template').value;
    document.getElementById('review-period').textContent = (document.getElementById('f-start').value || '—') + ' → ' + (document.getElementById('f-end').value || '—');
    document.getElementById('review-rebate').textContent = (document.getElementById('f-rebate').value || 0) + '%';
    document.getElementById('btn-form-next').textContent = '✓ Submit Contract';
  }
  if (dir === 1 && currentFormStep === 1) {
    if (!document.getElementById('f-customer').value) { toast('Customer name is required', ''); return; }
  }
  currentFormStep = Math.max(1, Math.min(3, currentFormStep + dir));
  updateFormSteps();
}

function updateFormSteps() {
  [1,2,3].forEach(i => {
    document.getElementById('form-step-content-'+i).style.display = i===currentFormStep?'block':'none';
    const stepEl = document.getElementById('form-step-'+i);
    stepEl.className = 'step' + (i<currentFormStep?' done':i===currentFormStep?' active':'');
    const dot = stepEl.querySelector('.step-dot');
    dot.textContent = i < currentFormStep ? '✓' : i;
  });
  document.getElementById('btn-form-back').style.display = currentFormStep > 1 ? '' : 'none';
  if (currentFormStep < 3) document.getElementById('btn-form-next').textContent = 'Next →';
  if (currentFormStep === 3) document.getElementById('btn-form-next').textContent = '✓ Submit Contract';
}

function submitNewContract() {
  const cust = document.getElementById('f-customer').value;
  if (!cust) { toast('Customer name required', ''); return; }
  const newId = 'CTR-2024-00' + (contracts.length + 1);
  const today = new Date().toISOString().split('T')[0];
  contracts.push({
    id: newId, customer: cust, email: document.getElementById('f-email').value,
    kam: 'Alice Müller', region: document.getElementById('f-region').value,
    value: parseInt(document.getElementById('f-value').value) || 0, status: 'Draft',
    created: today, start: document.getElementById('f-start').value, end: document.getElementById('f-end').value,
    template: document.getElementById('f-template').value, rebate: parseInt(document.getElementById('f-rebate').value)||0,
    volume: parseInt(document.getElementById('f-volume').value)||0, payment: document.getElementById('f-payment').value,
    counterpart: document.getElementById('f-counterpart').value, notes: document.getElementById('f-notes').value,
    obligations: document.getElementById('f-obligations').value, priority: document.getElementById('f-priority').value,
    comments: [], signedDate: null,
    attachedFile: attachedFile ? { name: attachedFile.name, size: attachedFile.size } : null
  });
  addActivity(`${newId} created (Draft)`, 'Today · Alice Müller', '');
  toast(newId + ' created as Draft!', 'success');
  attachedFile = null;
  closeModal('modal-new-contract');
  renderPage(getCurrentPage());
  updateBadges();
}

// ─── UTILS ────────────────────────────────────────────────────────────────────
function statusBadge(status) {
  const map = { 'Draft':'draft','Under Review':'review','Approved':'approved','E-Sign':'esign','Active':'active','Denied':'denied','Pending Review':'review' };
  return `<span class="status-badge ${map[status]||''}"><span class="dot"></span>${status}</span>`;
}

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function toast(msg, type) {
  const el = document.createElement('div');
  el.className = 'toast ' + (type||'');
  el.innerHTML = (type==='success'?'✅ ':type==='warn'?'⚠️ ':'ℹ️ ') + msg;
  document.getElementById('toast-container').appendChild(el);
  setTimeout(() => el.remove(), 3500);
}

function addActivity(text, sub, col) {
  activity.unshift({ text, sub, col });
  if (activity.length > 8) activity.pop();
}

function updateBadges() {
  document.getElementById('badge-contracts').textContent = contracts.length;
  document.getElementById('badge-review').textContent = contracts.filter(c=>c.status==='Under Review').length;
  document.getElementById('badge-plans').textContent = plans.filter(p=>p.status==='Pending Review').length;
}

// Close modal on overlay click
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', function(e) { if (e.target === this) this.classList.remove('open'); });
});

// ─── UPLOAD / DRAG-DROP ──────────────────────────────────────────────────────
let currentContractMode = 'form';
let uploadedFile = null;    // file attached in upload-mode
let attachedFile = null;    // file attached in form step 3

function switchContractMode(mode) {
  currentContractMode = mode;
  document.querySelectorAll('.upload-tab').forEach((t,i) => t.classList.toggle('active', (mode==='form'&&i===0)||(mode==='upload'&&i===1)));
  document.getElementById('contract-form-mode').style.display = mode === 'form' ? '' : 'none';
  document.getElementById('contract-upload-mode').style.display = mode === 'upload' ? '' : 'none';
  const footer = document.getElementById('contract-modal-footer');
  if (mode === 'upload') {
    footer.innerHTML = `
      <button class="btn btn-ghost" onclick="closeModal('modal-new-contract')">Cancel</button>
      <button class="btn btn-primary" id="btn-upload-submit" onclick="submitUploadedContract()" disabled style="opacity:0.5;cursor:not-allowed">Upload & Create Draft</button>
    `;
  } else {
    footer.innerHTML = `
      <button class="btn btn-ghost" id="btn-form-back" style="display:none" onclick="formStep(-1)">← Back</button>
      <button class="btn btn-ghost" onclick="closeModal('modal-new-contract')">Cancel</button>
      <button class="btn btn-primary" id="btn-form-next" onclick="formStep(1)">Next →</button>
    `;
    currentFormStep = 1;
    updateFormSteps();
  }
}

function getFileIcon(name) {
  const ext = name.split('.').pop().toLowerCase();
  return { pdf:'📕', docx:'📘', doc:'📘', xlsx:'📗', xls:'📗' }[ext] || '📄';
}

function formatBytes(b) {
  if (b < 1024) return b + ' B';
  if (b < 1024*1024) return (b/1024).toFixed(1) + ' KB';
  return (b/1024/1024).toFixed(1) + ' MB';
}

function renderFilePreview(file, containerId, onRemove) {
  const el = document.getElementById(containerId);
  el.style.display = 'block';
  el.innerHTML = `
    <div class="file-preview">
      <span class="file-icon">${getFileIcon(file.name)}</span>
      <div class="file-info">
        <div class="file-name">${file.name}</div>
        <div class="file-size">${formatBytes(file.size)} · Ready to attach</div>
      </div>
      <button class="file-remove" onclick="${onRemove}" title="Remove file">✕</button>
    </div>
  `;
}

// ── Main drop zone (Upload mode) ──
function handleMainDragOver(e) { e.preventDefault(); document.getElementById('main-drop-zone').classList.add('dragover'); }
function handleMainDragLeave(e) { document.getElementById('main-drop-zone').classList.remove('dragover'); }
function handleMainDrop(e) {
  e.preventDefault();
  document.getElementById('main-drop-zone').classList.remove('dragover');
  const files = e.dataTransfer.files;
  if (files.length) handleMainFileSelect(files);
}
function handleMainFileSelect(files) {
  if (!files.length) return;
  uploadedFile = files[0];
  const dz = document.getElementById('main-drop-zone');
  dz.classList.add('has-file');
  document.getElementById('drop-icon-main').textContent = '✅';
  document.getElementById('drop-title-main').textContent = 'File ready!';

  // Show upload progress animation
  document.getElementById('upload-progress-wrap').style.display = 'block';
  let pct = 0;
  const interval = setInterval(() => {
    pct = Math.min(pct + Math.random() * 18, 100);
    document.getElementById('upload-progress-fill').style.width = pct + '%';
    document.getElementById('upload-pct').textContent = Math.round(pct) + '%';
    if (pct >= 100) {
      clearInterval(interval);
      document.getElementById('upload-pct').textContent = '100%';
      renderFilePreview(uploadedFile, 'upload-file-preview', 'removeUploadFile()');
      document.getElementById('upload-progress-wrap').style.display = 'none';
      document.getElementById('upload-meta').style.display = 'block';
      const btn = document.getElementById('btn-upload-submit');
      if (btn) { btn.disabled = false; btn.style.opacity = '1'; btn.style.cursor = 'pointer'; }
    }
  }, 60);
}

function removeUploadFile() {
  uploadedFile = null;
  document.getElementById('upload-file-preview').style.display = 'none';
  document.getElementById('upload-meta').style.display = 'none';
  const dz = document.getElementById('main-drop-zone');
  dz.classList.remove('has-file');
  document.getElementById('drop-icon-main').textContent = '📂';
  document.getElementById('drop-title-main').textContent = 'Drag & drop your contract file';
  const btn = document.getElementById('btn-upload-submit');
  if (btn) { btn.disabled = true; btn.style.opacity = '0.5'; btn.style.cursor = 'not-allowed'; }
}

function submitUploadedContract() {
  const cust = document.getElementById('u-customer').value;
  if (!cust) { toast('Customer name is required', ''); return; }
  const newId = 'CTR-2024-00' + (contracts.length + 1);
  const today = new Date().toISOString().split('T')[0];
  contracts.push({
    id: newId, customer: cust, email: '', kam: 'Alice Müller',
    region: document.getElementById('u-region').value,
    value: parseInt(document.getElementById('u-value').value) || 0,
    status: 'Draft', created: today, start: '', end: '',
    template: 'Uploaded Document', rebate: 0, volume: 0,
    payment: 'Net 30', counterpart: 'None', notes: '',
    obligations: '', priority: document.getElementById('u-priority').value,
    comments: [], signedDate: null,
    attachedFile: uploadedFile ? { name: uploadedFile.name, size: uploadedFile.size } : null
  });
  addActivity(`${newId} uploaded (${uploadedFile?.name || 'file'})`, 'Today · Alice Müller', '');
  toast(`${newId} created from uploaded file!`, 'success');
  uploadedFile = null;
  closeModal('modal-new-contract');
  renderPage(getCurrentPage());
  updateBadges();
}

// ── Inline drop zone (Form step 3) ──
function handleInlineDragOver(e) { e.preventDefault(); document.getElementById('inline-drop').classList.add('dragover'); }
function handleInlineDragLeave() { document.getElementById('inline-drop').classList.remove('dragover'); }
function handleInlineDrop(e) {
  e.preventDefault();
  document.getElementById('inline-drop').classList.remove('dragover');
  if (e.dataTransfer.files.length) handleInlineFileSelect(e.dataTransfer.files);
}
function handleInlineFileSelect(files) {
  if (!files.length) return;
  attachedFile = files[0];
  document.getElementById('inline-drop').classList.add('has-file');
  renderFilePreview(attachedFile, 'inline-file-preview', 'removeInlineFile()');
  toast(`${attachedFile.name} attached`, 'success');
}
function removeInlineFile() {
  attachedFile = null;
  document.getElementById('inline-file-preview').style.display = 'none';
  document.getElementById('inline-drop').classList.remove('has-file');
}

// ─── GLOBAL DRAG-AND-DROP (anywhere on window) ────────────────────────────────
let dragCounter = 0;
window.addEventListener('dragenter', (e) => {
  if (!e.dataTransfer.types.includes('Files')) return;
  dragCounter++;
  document.getElementById('global-drop-overlay').classList.add('visible');
});
window.addEventListener('dragleave', () => {
  dragCounter--;
  if (dragCounter <= 0) { dragCounter = 0; document.getElementById('global-drop-overlay').classList.remove('visible'); }
});
window.addEventListener('dragover', (e) => e.preventDefault());
window.addEventListener('drop', (e) => {
  e.preventDefault();
  dragCounter = 0;
  document.getElementById('global-drop-overlay').classList.remove('visible');
  const files = e.dataTransfer.files;
  if (!files.length) return;
  // Only trigger if not in a modal
  if (document.querySelector('.modal-overlay.open')) return;
  // Open modal in upload mode with file pre-loaded
  if (currentRole !== 'kam') { toast('Only KAMs can upload contracts', ''); return; }
  openNewContract();
  switchContractMode('upload');
  // slight delay to let modal render
  setTimeout(() => handleMainFileSelect(files), 100);
});

// Init
renderDashboard();
</script>
